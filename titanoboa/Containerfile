# titanoboa/Containerfile
FROM ghcr.io/voidusx/sparrow:latest

# Copy ISO configuration
COPY iso.yaml /usr/lib/bootc-image-builder/iso.yaml

# Copy hook scripts (will be invoked by Titanoboa action, not run in container)
COPY titanoboa_hook_preinitramfs.sh /tmp/
COPY titanoboa_hook_postrootfs.sh /tmp/

# Ensure kernel/initramfs are in expected locations
RUN if [ ! -f /images/pxeboot/vmlinuz ]; then \
      mkdir -p /images/pxeboot && \
      cp /usr/lib/modules/*/vmlinuz /images/pxeboot/vmlinuz && \
      cp /usr/lib/modules/*/initramfs.img /images/pxeboot/initrd.img; \
    fi

LABEL org.opencontainers.image.title="Sparrow ISO Builder"
LABEL org.opencontainers.image.description="Sparrow with Titanoboa ISO configuration"
